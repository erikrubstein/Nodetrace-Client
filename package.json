{
  "name": "nodetrace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "concurrently \"npm run dev --workspace nodetrace-server\" \"npm run dev --workspace nodetrace-renderer\"",
    "dev:desktop": "concurrently \"npm run dev:renderer\" \"electron apps/desktop --dev-url=http://127.0.0.1:5173\"",
    "dev:server": "npm run dev --workspace nodetrace-server",
    "dev:renderer": "npm run dev --workspace nodetrace-renderer",
    "start": "npm run start:server",
    "start:server": "npm run start --workspace nodetrace-server",
    "start:desktop": "electron apps/desktop",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace nodetrace-renderer",
    "preview:web": "npm run preview --workspace nodetrace-renderer",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint .",
    "lint:server": "npm run lint --workspace nodetrace-server",
    "lint:renderer": "npm run lint --workspace nodetrace-renderer",
    "lint:desktop": "npm run lint --workspace nodetrace-desktop"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "vite": "^7.3.1"
  }
}
